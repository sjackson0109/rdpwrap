<?xml version="1.0" encoding="UTF-8"?>
<!--
  RDP Wrapper — MSI installer definition (WiX v5 / schema v4)
  Parameterised by MSBuild Platform: build once per arch.

  All install / uninstall logic is implemented natively in WiX — no helper EXE
  is launched as a CustomAction.  Operations performed by the MSI:

    INSTALL
      1. Stop TermService (ServiceControl)
      2. Write payload files to [INSTALLFOLDER]:
            rdpwrap.dll   rdpwrap.ini   RDPConf.exe   RDPCheck.exe
      3. Write Terminal Services registry values
      4. Set TermService\Parameters\ServiceDll → [INSTALLFOLDER]rdpwrap.dll
             (deferred CA via WixQuietExec + reg.exe, because the value is
              REG_EXPAND_SZ and must survive WOW64 registry reflection)
      5. Add Remote Desktop firewall exceptions TCP+UDP 3389 (FirewallExtension)
      6. Start TermService

    UNINSTALL
      1. Restore TermService\Parameters\ServiceDll → %SystemRoot%\System32\termsrv.dll
             (deferred CA — must happen BEFORE StopServices so that when the
              service restarts after uninstall it uses termsrv.dll, not the
              now-deleted rdpwrap.dll)
      2. Stop TermService
      3. Remove payload files
      4. Remove Terminal Services registry values
      5. Remove firewall exceptions
      6. Start TermService

  Build via:
    dotnet build msi/RDPWInst.wixproj -c Release /p:Platform=x64   /p:PackageVersion=yy.M.d
    dotnet build msi/RDPWInst.wixproj -c Release /p:Platform=x86   /p:PackageVersion=yy.M.d
    dotnet build msi/RDPWInst.wixproj -c Release /p:Platform=arm64 /p:PackageVersion=yy.M.d

  Required inputs alongside this file (produced by CI / build-local.ps1):
    RDPConf_<arch>.exe   RDPCheck_<arch>.exe
    rdpwrap_<arch>.dll
    rdpwrap.ini  (shared — same file for all arches)
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:fire="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <!--
    $(var.Platform) is automatically set by WiX from the MSBuild Platform property.
    x86 installs to Program Files (x86); x64/arm64 install to Program Files.
  -->
  <?if $(var.Platform) = "x64" ?>
    <?define Arch            = "x64" ?>
    <?define UpgradeCode     = "6623f60c-e84f-41e7-a55b-f42116500064" ?>
    <?define ProgramFilesDir = "ProgramFiles6432Folder" ?>
    <?define UtilBinaryRef   = "Wix4UtilCA_X64" ?>
    <?define WixQuietExecFn  = "WixQuietExec64" ?>
  <?elseif $(var.Platform) = "x86" ?>
    <?define Arch            = "x86" ?>
    <?define UpgradeCode     = "6623f60c-e84f-41e7-a55b-f42116500032" ?>
    <?define ProgramFilesDir = "ProgramFilesFolder" ?>
    <?define UtilBinaryRef   = "Wix4UtilCA_X86" ?>
    <?define WixQuietExecFn  = "WixQuietExec" ?>
  <?else ?>
    <?define Arch            = "arm64" ?>
    <?define UpgradeCode     = "6623f60c-e84f-41e7-a55b-f4211650aa64" ?>
    <?define ProgramFilesDir = "ProgramFiles6432Folder" ?>
    <?define UtilBinaryRef   = "Wix4UtilCA_A64" ?>
    <?define WixQuietExecFn  = "WixQuietExec64" ?>
  <?endif ?>

  <Package
    Name="RDP Wrapper Library ($(var.Arch))"
    Version="$(var.PackageVersion)"
    Manufacturer="Simon Jackson (@sjackson0109)"
    UpgradeCode="$(var.UpgradeCode)"
    Scope="perMachine"
    InstallerVersion="500"
    Compressed="yes">

    <!-- Allow upgrades, downgrades, and same-version reinstalls without blocking.
         Schedule=afterInstallInitialize ensures the old product is fully removed
         before new files are written, preventing component-ownership conflicts. -->
    <MajorUpgrade
      Schedule="afterInstallInitialize"
      AllowDowngrades="yes"
      IgnoreRemoveFailure="yes" />

    <MediaTemplate EmbedCab="yes" />

    <!-- ── Installation directory ─────────────────────────────────────────── -->
    <StandardDirectory Id="$(var.ProgramFilesDir)">
      <Directory Id="INSTALLFOLDER" Name="RDP Wrapper" />
    </StandardDirectory>

    <!-- ── Feature ────────────────────────────────────────────────────────── -->
    <Feature Id="ProductFeature" Title="RDP Wrapper" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>

    <!-- ════════════════════════════════════════════════════════════════════
         ServiceDll Custom Actions
         ════════════════════════════════════════════════════════════════════

         WiX deferred CAs run with elevated privileges and cannot read installer
         properties directly.  The SetProperty (immediate) actions below format
         the command-line strings while [INSTALLFOLDER] is still available, and
         store the result as CustomActionData for the matching deferred CA.

         WixQuietExec reads CustomActionData as the command to run silently.
    -->

    <!-- On INSTALL: write ServiceDll = [INSTALLFOLDER]rdpwrap.dll -->
    <SetProperty
      Id="CA_SetServiceDll"
      Value="&quot;[SystemFolder]reg.exe&quot; add &quot;HKLM\SYSTEM\CurrentControlSet\Services\TermService\Parameters&quot; /v ServiceDll /t REG_EXPAND_SZ /d &quot;[INSTALLFOLDER]rdpwrap.dll&quot; /f"
      Before="CA_SetServiceDll"
      Sequence="execute" />

    <CustomAction
      Id="CA_SetServiceDll"
      BinaryRef="$(var.UtilBinaryRef)"
      DllEntry="$(var.WixQuietExecFn)"
      Execute="deferred"
      Impersonate="no"
      Return="check" />

    <!-- On UNINSTALL: restore ServiceDll = %SystemRoot%\System32\termsrv.dll -->
    <SetProperty
      Id="CA_RestoreServiceDll"
      Value="&quot;[SystemFolder]reg.exe&quot; add &quot;HKLM\SYSTEM\CurrentControlSet\Services\TermService\Parameters&quot; /v ServiceDll /t REG_EXPAND_SZ /d &quot;%SystemRoot%\System32\termsrv.dll&quot; /f"
      Before="CA_RestoreServiceDll"
      Sequence="execute" />

    <CustomAction
      Id="CA_RestoreServiceDll"
      BinaryRef="$(var.UtilBinaryRef)"
      DllEntry="$(var.WixQuietExecFn)"
      Execute="deferred"
      Impersonate="no"
      Return="check" />

    <!-- ── Execute sequence ─────────────────────────────────────────────── -->
    <InstallExecuteSequence>
      <!--
        Install:   set ServiceDll after registry and files are in place,
                   but before StartServices restarts TermService.
        Uninstall: restore ServiceDll BEFORE StopServices so that when
                   StartServices runs at the end of uninstall, TermService
                   can load termsrv.dll (which is still on disk at that point).
      -->
      <Custom Action="CA_SetServiceDll"     After="WriteRegistryValues"
              Condition="NOT REMOVE" />
      <Custom Action="CA_RestoreServiceDll" Before="StopServices"
              Condition="REMOVE" />
    </InstallExecuteSequence>
  </Package>

  <!-- ════════════════════════════════════════════════════════════════════════
       Component Group
       ════════════════════════════════════════════════════════════════════════ -->
  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

      <!-- ── rdpwrap.dll — core RDP wrapper DLL ─────────────────────────── -->
      <!--
        Source filename is arch-qualified (rdpwrap_x64.dll etc.) so CI can stage
        all arches in the same directory; Name ensures the installed name is always
        "rdpwrap.dll" regardless of arch suffix.

        ServiceControl lives here so the stop/start is tied to the component that
        owns the DLL being swapped out.  Stop="both" / Start="both" means the
        service is stopped before and restarted after every install, upgrade, or
        uninstall — ensuring TermService never tries to load a partially written
        or already-deleted rdpwrap.dll.

        FirewallException elements are also co-located with the DLL: they are
        added at install time and removed automatically when this component is
        removed (uninstall / upgrade).
      -->
      <Component Id="RdpwrapDll_Comp" Guid="*">
        <File Id="RdpwrapDll"
              Source="rdpwrap_$(var.Arch).dll"
              Name="rdpwrap.dll"
              KeyPath="yes" />

        <!-- Stop TermService before the DLL is laid down; restart after config -->
        <ServiceControl Id="TermService_Control"
                        Name="TermService"
                        Stop="both"
                        Start="both"
                        Wait="yes" />

        <!-- Remote Desktop firewall rules — created on install, removed on uninstall -->
        <fire:FirewallException
          Id="RDP_TCP"
          Name="Remote Desktop"
          Port="3389"
          Protocol="tcp"
          Profile="all"
          Scope="any" />

        <fire:FirewallException
          Id="RDP_UDP"
          Name="Remote Desktop (UDP)"
          Port="3389"
          Protocol="udp"
          Profile="all"
          Scope="any" />
      </Component>

      <!-- ── rdpwrap.ini — patch / offset database ───────────────────────── -->
      <Component Id="RdpwrapIni_Comp" Guid="*">
        <File Id="RdpwrapIni" Source="rdpwrap.ini" KeyPath="yes" />
      </Component>

      <!-- ── RDPConf — configuration GUI ────────────────────────────────── -->
      <Component Id="RDPConfExe_Comp" Guid="*">
        <File Id="RDPConfExe"
              Source="RDPConf_$(var.Arch).exe"
              Name="RDPConf.exe"
              KeyPath="yes" />
      </Component>

      <!-- ── RDPCheck — loopback RDP connectivity tester ─────────────────── -->
      <Component Id="RDPCheckExe_Comp" Guid="*">
        <File Id="RDPCheckExe"
              Source="RDPCheck_$(var.Arch).exe"
              Name="RDPCheck.exe"
              KeyPath="yes" />
      </Component>

      <!-- ── Terminal Services registry configuration ─────────────────────── -->
      <!--
        All values below are REMOVED when this component is uninstalled (MSI
        default behaviour for RegistryValue elements).  Removing fDenyTSConnections
        restores the system default (deny remote connections), which is the correct
        post-uninstall state on a workstation.  The remaining keys revert by absence.
      -->
      <Component Id="TSConfig_Comp" Guid="*">

        <!-- Allow remote desktop connections -->
        <RegistryValue
          Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Control\Terminal Server"
          Name="fDenyTSConnections"
          Value="0"
          Type="integer"
          KeyPath="yes" />

        <!-- Allow concurrent (multi-user) sessions -->
        <RegistryValue
          Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Control\Terminal Server\Licensing Core"
          Name="EnableConcurrentSessions"
          Value="1"
          Type="integer" />

        <!-- Allow multiple TS sessions via Winlogon -->
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\Microsoft\Windows NT\CurrentVersion\Winlogon"
          Name="AllowMultipleTSSessions"
          Value="1"
          Type="integer" />

        <!-- Allow remote RPC access -->
        <RegistryValue
          Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Control\Terminal Server"
          Name="AllowRemoteRPC"
          Value="1"
          Type="integer" />

        <!-- Allow linked connections (required by certain group policies) -->
        <RegistryValue
          Root="HKLM"
          Key="SYSTEM\CurrentControlSet\Control\Terminal Server"
          Name="EnableLinkedConnections"
          Value="1"
          Type="integer" />

      </Component>

    </ComponentGroup>
  </Fragment>

</Wix>
